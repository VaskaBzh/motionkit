{
  "name": "@motionlab/motionkit",
  "version": "0.1.1",
  "description": "FLIP card animations library for TypeScript and Vue 3",
  "keywords": [
    "animation",
    "flip",
    "motion",
    "vue",
    "typescript",
    "web-animations",
    "cards"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/VaskaBzh/motionkit.git"
  },
  "homepage": "https://github.com/VaskaBzh/motionkit#readme",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "types": "./dist/core/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "types": "./dist/core/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs",
      "types": "./dist/vue/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "types": "./dist/react/index.d.ts"
    },
    "./angular": {
      "import": "./dist/angular.js",
      "require": "./dist/angular.cjs",
      "types": "./dist/angular/index.d.ts"
    }
  },
  "main": "./dist/core.cjs",
  "module": "./dist/core.js",
  "types": "./dist/core/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:angular": "vite --config vite.demo.angular.config.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@angular/core": "^17.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.2",
    "@angular/animations": "^21.2.14",
    "@angular/build": "^21.2.12",
    "@angular/common": "^21.2.14",
    "@angular/compiler": "^21.2.14",
    "@angular/compiler-cli": "^21.2.14",
    "@angular/core": "^21.2.14",
    "@angular/platform-browser": "^21.2.14",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "happy-dom": "^20.9.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "zone.js": "^0.15.1"
  }
}
